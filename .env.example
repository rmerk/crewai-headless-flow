# =============================================================================
# crewai-headless-flow — Environment Configuration
# =============================================================================
# Copy to .env and fill in what you need.
#
# COST MODEL (per the project charter):
# - Orchestration LLM (planning, routing, light reasoning) = LOCAL OLLAMA ($0)
# - The actual coding work = pluggable headless coder (Codex or Grok) — OPT-IN
#
# Auth for the two headless workers lives here. Never hard-code keys.
# =============================================================================

# -----------------------------------------------------------------------------
# Orchestration (always cheap / local first)
# -----------------------------------------------------------------------------
# Point at your local Ollama. Used for the "brain" (plan stage + router decisions).
OLLAMA_BASE_URL=http://localhost:11434
# Model string passed to crewai / litellm. Examples:
#   ollama/llama3.2
#   ollama/qwen2.5-coder:7b
#   ollama/phi3:mini
OLLAMA_MODEL=ollama/llama3.2

# -----------------------------------------------------------------------------
# Codex (OpenAI / ChatGPT plan) — one of the two pluggable coding workers
# -----------------------------------------------------------------------------
# Required when you set a stage's worker to "codex" in config/worker.yaml.
# Either a ChatGPT Plus/Pro plan (uses the codex CLI's built-in auth)
# or an OPENAI_API_KEY if using the raw API path.
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Grok / xAI — the other pluggable coding worker
# -----------------------------------------------------------------------------
# Required when you set a stage's worker to "grok".
# Get a key at https://x.ai (XAI_API_KEY).
# XAI_API_KEY=xai-...

# -----------------------------------------------------------------------------
# Optional: project-specific overrides
# -----------------------------------------------------------------------------
# TARGET_REPO=/path/to/the/repo/you/want/to/modify
# MAX_REVISIONS=2
# ENABLE_HUMAN_FEEDBACK=false
